{
  "id": "walrus-r1",
  "name": "Walrus Audio R1",
  "manufacturer": "Walrus Audio",
  "defaultChannel": 4,
  "bypassCC": 30,
  "category": "reverb",
  "midiOutputName": "HX Effects",
  "stereoLinked": false,
  "ccSendOrder": [
