      "min": 0,
      "max": 127,
      "default": 64,
      "group": "tone",
      "order": 7,
      "description": "Low-frequency content in the reverb tail"
    },
    {
      "id": "r1-high",
      "label": "High",
      "cc": 25,
      "type": "continuous",
      "min": 0,
      "max": 127,
      "default": 64,
      "group": "tone",
      "order": 8,
      "description": "High-frequency content in the reverb tail"
