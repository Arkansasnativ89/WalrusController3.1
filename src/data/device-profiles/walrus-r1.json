        { "label": "Bank A", "value": 21, "range": [0, 42] },
        { "label": "Bank B", "value": 64, "range": [43, 85] },
        { "label": "Bank C", "value": 106, "range": [86, 127] }
      ]
    },
    {
      "id": "r1-tune-switch",
