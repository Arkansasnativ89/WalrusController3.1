      "dynamicLabel": {
        "controlledBy": "r1-prog",
        "entries": [
          { "whenValue": 1, "label": "Spring Size", "description": "Short small spring → overt slap-back" },
          { "whenValue": 2, "label": "Room Size", "description": "Small intimate room → massive arena hall" },
          { "whenValue": 3, "label": "Grit / Drive", "description": "Clean plate → warm driven signal grit" },
          { "whenValue": 4, "label": "Diffusion", "description": "Delay taps exposed → smooth reverb wash" },
          { "whenValue": 5, "label": "Diffusion", "description": "Less diffused/textural → heavily diffused reverb" },
          { "whenValue": 6, "label": "Shimmer", "description": "Shimmer off (clean reverb) → full +12 semitone octave shimmer" }
        ]
      }
    },
