      "id": "r1-prog",
      "label": "Reverb Program",
      "cc": 23,
      "type": "select",
      "min": 1,
      "max": 6,
      "default": 1,
      "group": "program",
      "order": 0,
      "description": "Reverb algorithm. Changes behavior of X, Rate, and Depth parameters.",
      "options": [
        { "label": "Spring", "value": 1 },
        { "label": "Hall", "value": 2 },
        { "label": "Plate", "value": 3 },
        { "label": "BFR", "value": 4 },
        { "label": "RFRCT", "value": 5 },
        { "label": "Air", "value": 6 }
      ]
    },
    {
      "id": "r1-decay",
      "label": "Decay",
