      "type": "continuous",
      "min": 0,
      "max": 127,
      "default": 40,
      "group": "modulation",
      "order": 4,
      "description": "Modulation speed within the reverb"
    },
    {
      "id": "r1-depth",
      "label": "Depth",
      "cc": 21,
      "type": "continuous",
      "min": 0,
      "max": 127,
      "default": 40,
      "group": "modulation",
      "order": 5,
      "description": "Modulation intensity within the reverb"
    },
    {
