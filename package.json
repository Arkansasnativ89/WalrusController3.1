{
  "name": "walrus-controller",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Browser-based MIDI controller for Walrus Audio pedals",
  "author": "Hunter Carle",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-icons.mjs && tsc -b && vite build",
    "preview": "vite preview",
    "serve": "npm run build && vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dexie": "^4.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.12"
  },
  "overrides": {
    "serialize-javascript": "^7.0.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "jsdom": "^29.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0"
  }
}
